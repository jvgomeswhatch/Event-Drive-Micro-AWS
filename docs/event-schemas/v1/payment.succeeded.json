{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://platform/events/v1/payment.succeeded",
  "title": "payment.succeeded",
  "description": "Emitido pelo payment-service quando um pagamento é processado com sucesso.",
  "version": "1",
  "type": "object",
  "required": ["eventType", "version", "paymentId", "orderId", "customerId", "items", "totalAmount", "status", "_meta"],
  "additionalProperties": false,
  "properties": {
    "eventType":   { "type": "string", "const": "payment.succeeded" },
    "version":     { "type": "string", "const": "1" },
    "paymentId":   { "type": "string", "format": "uuid" },
    "orderId":     { "type": "string", "format": "uuid" },
    "customerId":  { "type": "string", "minLength": 1, "maxLength": 128 },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["productId", "quantity"],
        "additionalProperties": false,
        "properties": {
          "productId": { "type": "string" },
          "quantity":  { "type": "integer", "minimum": 1 }
        }
      }
    },
    "totalAmount": { "type": "number", "minimum": 0 },
    "status":      { "type": "string", "const": "succeeded" },
    "_meta":       { "$ref": "#/definitions/EventMeta" }
  },
  "definitions": {
    "EventMeta": {
      "type": "object",
      "required": ["correlationId", "publishedAt", "publisher"],
      "additionalProperties": false,
      "properties": {
        "correlationId": { "type": "string" },
        "publishedAt":   { "type": "string", "format": "date-time" },
        "publisher":     { "type": "string", "const": "payment-service" }
      }
    }
  }
}
