{
  "title": "Platform — Order Flow",
  "uid": "platform-order-flow",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "All Service Logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true },
      "targets": [
        {
          "expr": "{job=~\"order-service|payment-service|inventory-service|notification-service\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "logs",
      "title": "Trace by Correlation ID — filter: correlationId",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "showTime": true, "sortOrder": "Ascending", "wrapLogMessage": true },
      "targets": [
        {
          "expr": "{job=~\".+\"} | json | correlationId=`$correlationId`",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "logs",
      "title": "Span Timeline — operation durations",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "showTime": true, "sortOrder": "Ascending" },
      "targets": [
        {
          "expr": "{job=~\".+\"} | json | message=`span finished`",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "logs",
      "title": "Errors & DLQ Events",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 30 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "showTime": true, "sortOrder": "Descending" },
      "targets": [
        {
          "expr": "{job=~\".+\"} | json | level=`error` or level=`warn`",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "correlationId",
        "type": "textbox",
        "label": "Correlation ID",
        "current": { "value": "" }
      }
    ]
  }
}
