# LocalStack
LOCALSTACK_ENDPOINT=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# App
NODE_ENV=development
LOG_LEVEL=info

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRY=3600

# Services
ORDER_SERVICE_PORT=3001
PAYMENT_SERVICE_PORT=3002
INVENTORY_SERVICE_PORT=3003
NOTIFICATION_SERVICE_PORT=3004

# SQS Queue names (resolved at runtime via Terraform outputs)
ORDER_QUEUE_NAME=order-queue-dev
PAYMENT_QUEUE_NAME=payment-queue-dev
INVENTORY_QUEUE_NAME=inventory-queue-dev
NOTIFICATION_QUEUE_NAME=notification-queue-dev

ORDER_DLQ_NAME=order-dlq-dev
PAYMENT_DLQ_NAME=payment-dlq-dev
INVENTORY_DLQ_NAME=inventory-dlq-dev
NOTIFICATION_DLQ_NAME=notification-dlq-dev

# SNS Topic names
ORDER_EVENTS_TOPIC_NAME=order-events-dev
PAYMENT_EVENTS_TOPIC_NAME=payment-events-dev
INVENTORY_EVENTS_TOPIC_NAME=inventory-events-dev

# DynamoDB table names
ORDERS_TABLE=orders-dev
PAYMENTS_TABLE=payments-dev
INVENTORY_TABLE=inventory-dev
IDEMPOTENCY_TABLE=idempotency-dev

# Frontend
VITE_API_BASE_URL=http://localhost:4566/restapis
VITE_WS_URL=ws://localhost:4566
VITE_CORRELATION_DEBUG=true

# Segurança — CORS
# Em dev: deixe em branco para permitir qualquer origem
# Em produção: defina as origens permitidas separadas por vírgula
# Exemplo: CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=
